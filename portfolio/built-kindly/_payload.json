w.datocms-assets.com/163973/1754416409-bk-cs-5.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1754416409-bk-cs-5.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1754416409-bk-cs-5.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1754416409-bk-cs-5.png?auto=format&fit=max&h=2440&q=85&w=2440",1785,1.366782006920415,"data:image/jpeg;base64,","#accfb6",{"id":131,"type":132,"title":133,"subtitle":134,"text":135,"media":136,"reverse":141},"NMHyRGDGSKyTM5KOA8Tj6g","text_device_block","The Solve","A brand that feels like us, and works like we do.","\u003Cp>Today, APEX Experts is live: a visual and verbal identity that matches the way we build things. It flexes from logo to website to illustrations to motion to the industry work we put out into the world.\u003C/p>\n\u003Cp>It&rsquo;s a kind brand, but it&rsquo;s not soft. It&rsquo;s creative, unexpected, and built to stand out in all the right ways.\u003C/p>",{"id":137,"media":138,"device":32},"adUqdyCLTNejIAGxh7Hn6w",{"id":13,"alt":14,"title":14,"focalPoint":139,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":140,"video":14},{"x":16,"y":16},{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},false,{"id":143,"slug":144,"title":145,"featuredMedia":146},"D5CqpIg_RA-DNsC_w4P5Iw","vital-access","Vital Access",{"id":147,"media":148,"device":163},"Rp5KiVCsTxyxuSHaLX8PBg",{"id":149,"alt":14,"title":14,"focalPoint":150,"width":151,"height":152,"thumbnail":153,"small":154,"medium":155,"responsiveImage":156,"video":14},"AVllGn5ESNey_EsZKs3b6Q",{"x":16,"y":16},1338,1003,"/home.mp4","/home.mp4","/home.mp4",{"srcSet":157,"webpSrcSet":24,"sizes":158,"src":159,"width":151,"height":152,"aspectRatio":160,"alt":14,"title":14,"base64":161,"bgColor":162},"/home.mp4","(max-width: 1338px) 100vw, 1338p