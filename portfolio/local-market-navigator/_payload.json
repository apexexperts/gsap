ps://www.datocms-assets.com/163973/1756763101-lmd_grid3.png?auto=format&fit=max&h=2440&q=85&w=2440 1580w","(max-width: 1580px) 100vw, 1580px","https://www.datocms-assets.com/163973/1756763101-lmd_grid3.png?auto=format&fit=max&h=2440&q=85&w=2440",1.365600691443388,"data:image/png;base64,",{"id":152,"type":153,"title":154,"subtitle":155,"text":156,"media":157,"reverse":162},"DBEgfv9sR1eUPL5mQkTimQ","text_device_block","The Solve.","Live, in use, and ready for your brand.","\u003Cp>The Local Market Navigator is already helping clients turn field insights into action, surfacing up-to-date data on drug performance, regional dynamics, and local opportunities at the ZIP, local market, and HCP level.\u003C/p>\n\u003Cp>It&rsquo;s a powerful product that can be fully customized to match your brand strategy and priorities, ensuring it delivers the same kind of impact on your teams.\u003C/p>",{"id":158,"media":159,"device":32},"WG6Wthq9QkmkLBI5rXpvcg",{"id":13,"alt":14,"title":14,"focalPoint":160,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":161,"video":14},{"x":16,"y":16},{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},false,{"id":164,"slug":165,"title":166,"featuredMedia":167},"Xvp1eLItTZ6RYi1Ls2SKIQ","time-being","Time Being",{"id":168,"media":169,"device":32},"GivOGx28RGKl9xKmCdOQfg",{"id":170,"alt":14,"title":14,"focalPoint":171,"width":172,"height":173,"thumbnail":174,"small":175,"medium":176,"responsiveImage":177,"video":14},"MNSjiafIQnm3XTfxMNEYFw",{"x":16,"y":16},2858,1672,"https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":178,"webpSrcSet":24,"sizes":25,"src":179,"width":27,"height":180,"aspec