[{"data":1,"prerenderedAt":184},["ShallowReactive",2],{"portfolio-local-market-navigator":3},{"page":4,"next":163},{"id":5,"slug":6,"title":7,"displayTitle":8,"intro":9,"featuredMedia":10,"blocks":33},"HMVpoTe3Q6a-fcEU8BSCVg","local-market-navigator","Local Market Navigator","Clarity That Moves Markets","\u003Cp>\u003Cstrong>Local Market Navigator\u003C/strong> makes it easier to explore performance data, uncover patterns, and act smarter&mdash;without digging through decks and databases\u003Cspan>.\u003C/span>\u003C/p>",{"id":11,"media":12,"device":32},"Q_3qnxpvTR6CJfz8PwF63g",{"id":13,"alt":14,"title":14,"focalPoint":15,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":22,"video":14},"URZdA1-vRcGxz619Zx1PCA",null,{"x":16,"y":16},0.5,2880,1684,"https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},"https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","","(max-width: 2440px) 100vw, 2440px","https://www.datocms-assets.com/163973/1756764332-lmd_dash.png?auto=format&fit=max&h=2440&q=85&w=2440",2440,1426,1.7102137767220904,"data:image/jpeg;base64,","#ffb102","laptop",[34,100,151],{"id":35,"type":36,"device":32,"items":37},"Liqi4XM-Qw2NvZvMun7lvQ","steps_block",[38,62,79],{"id":39,"media":40,"title":43,"subtitle":44,"text":45,"list":46,"link":58},"fD6ZtNryQGOoDgc8QDUNfg",{"id":13,"alt":14,"title":14,"focalPoint":41,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":42,"video":14},{"x":16,"y":16},{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},"Product Snapshot.","What we built and why we built it.","\u003Cp>The Local Market Navigator turns PowerPoints, spreadsheets, and static updates into something dynamic, visual, and ready to use. Built by Built Kindly in partnership with Profero, it helps field teams \u003Cspan>assess\u003C/span> what&rsquo;s happening in their local market&mdash;faster, clearer, and more contextually.\u003C/p>\n\u003Cp>Users arrive at a familiar map of the U.S., already divided into their assigned areas. With one click, they can explore specific local markets to see territory-specific goals, performance trends, account activity, HCP-level insights, and more. Or they can also skip the map and use the global search bar to jump straight to any local market in seconds.\u003C/p>\n\u003Cp>Local insights don&rsquo;t belong in spreadsheets. They belong in action.\u003C/p>",[47,50,54],{"id":48,"label":49,"text":7},"SvX2iw-TTjaFVQB5klcvAg","Product Name",{"id":51,"label":52,"text":53},"Lt-5LjSzTN-bEtX8rLiG9A","Launched","May 2025",{"id":55,"label":56,"text":57},"az0nKXXVSGyaSQNPkwfagQ","Type","Internal Field Tool / Web-Based",{"id":59,"label":60,"internal":14,"external":61},"VeUOs8RqSOmV393lp-V4mw","Email Us to Schedule a Demo","mailto:info@builtkindly.com?subject=Schedule a Local Market Navigator Demo",{"id":63,"media":64,"title":75,"subtitle":76,"text":77,"list":78,"link":14},"fehzWG0zT6S7kKdH7JtbDA",{"id":65,"alt":14,"title":14,"focalPoint":66,"width":17,"height":18,"thumbnail":67,"small":68,"medium":69,"responsiveImage":70,"video":14},"bXJirEWBT4OoxJyDwcHCAw",{"x":16,"y":16},"https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":71,"webpSrcSet":24,"sizes":25,"src":72,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":73,"bgColor":74},"https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1756764867-lmd_area.png?auto=format&fit=max&h=2440&q=85&w=2440","data:image/jpeg;base64,","#f2ba11","The Spark.","What if teams always had the right insight—right when they need it?","\u003Cp>For years, Profero has helped clients deliver incredibly rich access data to the field, complete with performance trends, segment strategies, and actionable recommendations. But getting reps to use it? That is another story. Spreadsheets get skimmed, PowerPoints get buried, insights get overlooked, and opportunities get missed.\u003C/p>\n\u003Cp>So we built something better: a tool that makes the local market feel local again.\u003C/p>",[],{"id":80,"media":81,"title":96,"subtitle":97,"text":98,"list":99,"link":14},"UL4zZLuFQB-ja2oyg2OdSg",{"id":82,"alt":14,"title":14,"focalPoint":83,"width":84,"height":85,"thumbnail":86,"small":87,"medium":88,"responsiveImage":89,"video":14},"PjbkFwa5Te-6d7kywT663A",{"x":16,"y":16},1600,936,"https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":90,"webpSrcSet":24,"sizes":91,"src":92,"width":84,"height":85,"aspectRatio":93,"alt":14,"title":14,"base64":94,"bgColor":95},"https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 400w,https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 800w,https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1200w,https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&fit=max&h=2440&q=85&w=2440 1600w","(max-width: 1600px) 100vw, 1600px","https://www.datocms-assets.com/163973/1757098126-lmd_map.png?auto=format&fit=max&h=2440&q=85&w=2440",1.7094017094017093,"data:image/png;base64,","#27517e","The Problem.","The insights were strong—but the formats weren’t.","\u003Cp data-start=\"213\" data-end=\"490\">For area managers, the data was there&mdash;but never in one place. Insights lived in spreadsheets, emails, decks&hellip; and required too much stitching together to be truly useful. Each view showed a slice, rarely the whole picture.\u003C/p>\n\u003Cp data-start=\"492\" data-end=\"708\">What was missing was a single, interactive view. A way to dig into each CBSA, spot trends, guide the field, and export what mattered most&mdash;so managers could coach smarter, act faster, and bring local strategy to life.\u003C/p>",[],{"id":101,"type":102,"title":103,"subtitle":104,"text1":105,"text2":106,"media":107},"R8K08zOAQDKRkw4pPz9wwQ","image_grid_block","The Process.","From database to product—with zero loss of clarity.","\u003Cp>Profero already does the work for the data, the story, and segmentation strategy. They just needed a better way to deliver it. Together, we translated those data sets into dynamic dashboards, mapping the architecture, defining workflows, and building it all in a scalable, rebrandable framework. Our goal: keep the strategy, remove the struggle.\u003C/p>","\u003Cp>All the same thoughtful data work that Profero was delivering before is now a tap or hover away. Fast, intuitive, and built for real-world use. Tables are sortable, metrics are visual, sections are exportable, and admins can even control access and user groups, all from one simple backend.\u003C/p>",[108,122,137],{"id":109,"alt":14,"title":14,"focalPoint":110,"width":111,"height":112,"thumbnail":113,"small":114,"medium":115,"responsiveImage":116,"video":14},"ZxDYdgIHQnKqleCL_gJ3UQ",{"x":16,"y":16},2640,1156,"https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":117,"webpSrcSet":24,"sizes":25,"src":118,"width":27,"height":119,"aspectRatio":120,"alt":14,"title":14,"base64":121,"bgColor":31},"https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1756763101-lmd_grid1.png?auto=format&fit=max&h=2440&q=85&w=2440",1068,2.2837370242214536,"data:image/jpeg;base64,",{"id":123,"alt":14,"title":14,"focalPoint":124,"width":125,"height":126,"thumbnail":127,"small":128,"medium":129,"responsiveImage":130,"video":14},"dXakT680RBWtaXpeIOsMVQ",{"x":16,"y":16},941,1158,"https://www.datocms-assets.com/163973/1756763101-lmd_grid2.png?auto=format&fit=max&h=600&q=85&w=600",