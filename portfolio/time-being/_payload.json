[{"data":1,"prerenderedAt":184},["ShallowReactive",2],{"portfolio-time-being":3},{"page":4,"next":163},{"id":5,"slug":6,"title":7,"displayTitle":8,"intro":9,"featuredMedia":10,"blocks":33},"Xvp1eLItTZ6RYi1Ls2SKIQ","time-being","Time Being","A Kinder Clock for the Workday","\u003Cp>\u003Cstrong>Time Being\u003C/strong> brings balance to the timesheet, helping teams stay accountable to the work. And to themselves.\u003C/p>",{"id":11,"media":12,"device":32},"GivOGx28RGKl9xKmCdOQfg",{"id":13,"alt":14,"title":14,"focalPoint":15,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":22,"video":14},"MNSjiafIQnm3XTfxMNEYFw",null,{"x":16,"y":16},0.5,2858,1672,"https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},"https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","","(max-width: 2440px) 100vw, 2440px","https://www.datocms-assets.com/163973/1756814206-tb_dash.png?auto=format&fit=max&h=2440&q=85&w=2440",2440,1427,1.7093301435406698,"data:image/jpeg;base64,","#71be46","laptop",[34,99,151],{"id":35,"type":36,"device":32,"items":37},"OoIkNRfjTjOlzeSBA_8mpg","steps_block",[38,62,79],{"id":39,"media":40,"title":43,"subtitle":44,"text":45,"list":46,"link":58},"UW3GguOyQXa8kbHs0kopcw",{"id":13,"alt":14,"title":14,"focalPoint":41,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":42,"video":14},{"x":16,"y":16},{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},"Product Snapshot","What we built and why we built it.","\u003Cp>Time Being is a timesheet tool built to help people manage their work time and their well-being. Equally.\u003C/p>\n\u003Cp>It brings thoughtful UX, smart insights, and a radically human-centered approach to something teams use every day. Created by APEX Experts to shift how organizations track time and manage burnout, it includes helpful tools like BurnTrack, which surfaces well-being at a glance, and a universal search-and-start menu to reduce clicks and streamline entries. The experience is fast, kind, and intuitive&mdash;because that&rsquo;s how time should feel.\u003C/p>",[47,50,54],{"id":48,"label":49,"text":7},"X6nsCFd-TcqUnY8i2SeUHg","Product Name:",{"id":51,"label":52,"text":53},"dhwSqMS5RC6pVQq9ogv2wg","Launched:","January 2026",{"id":55,"label":56,"text":57},"J41Rc7RLRlaOspNV2NjKMQ","Type:","Web-based App",{"id":59,"label":60,"internal":14,"external":61},"fQcehACYT32kmw26V8lHXw","Contact Us to Schedule a Demo","mailto:info@builtkindly.com?subject=Schedule a Time Being Demo",{"id":63,"media":64,"title":75,"subtitle":76,"text":77,"list":78,"link":14},"Y0wmmjdlRkyIIgn4FkB_Kw",{"id":65,"alt":14,"title":14,"focalPoint":66,"width":17,"height":18,"thumbnail":67,"small":68,"medium":69,"responsiveImage":70,"video":14},"QvA55nBCS4mC4s-Bvj6xIA",{"x":16,"y":16},"https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":71,"webpSrcSet":24,"sizes":25,"src":72,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":73,"bgColor":74},"https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1756814185-tb_dropdowns.png?auto=format&fit=max&h=2440&q=85&w=2440","data:image/jpeg;base64,","#d45a4a","The Spark.","We knew time tracking could do more—if it looked out for the people behind the numbers.","\u003Cp>Most tools stop at what was done. But we wanted to build something that also asks how it felt. What if teams could track time and catch burnout early? What if managers had real insight into team load&mdash;without micromanaging? Time Being started as a better way to log time, and quickly became a smarter way to support it.\u003C/p>",[],{"id":80,"media":81,"title":95,"subtitle":96,"text":97,"list":98,"link":14},"C4MNrMIAR1WuHGeSOcZDgg",{"id":82,"alt":14,"title":14,"focalPoint":83,"width":84,"height":18,"thumbnail":85,"small":86,"medium":87,"responsiveImage":88,"video":14},"ajhCyEjcRC-_rHLttNhBIg",{"x":16,"y":16},2880,"https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":89,"webpSrcSet":24,"sizes":25,"src":90,"width":27,"height":91,"aspectRatio":92,"alt":14,"title":14,"base64":93,"bgColor":94},"https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1756814225-tb_time.png?auto=format&fit=max&h=2440&q=85&w=2440",1416,1.722488038277512,"data:image/jpeg;base64,","#01aeaf","The Problem.","We were tired of tools that rewarded overwork and ignored overload.","\u003Cp>For years, teams used systems that treated burnout like a badge. Employees were quietly working overtime, skipping PTO, and drowning in meetings&mdash;with no tool stepping in to help them course correct. Managers couldn&rsquo;t see the warning signs. And team health was slipping through the cracks. Time tracking had become an administrative task, instead of a human one.\u003C/p>",[],{"id":100,"type":101,"title":102,"subtitle":103,"text1":104,"text2":105,"media":106},"IVwRyj5sTTO3n5mx--lh1Q","image_grid_block","The Process.","From stress signals to a system that actually supports people.","\u003Cp>We mapped out every role and listened closely to how people \u003Cem data-start=\"319\" data-end=\"327\">wished\u003C/em> these tools worked. From that, we built BurnTrack: a live well-being indicator that factors in meetings, hours, PTO, and overtime into a single, color-coded score.\u003C/p>","\u003Cp data-start=\"493\" data-end=\"690\">We also designed a mental health&ndash;focused notification system that encourages manager accountability&mdash;and added a built-in binaural beats player to help employees reset without ever leaving the tool.\u003C/p>",[107,122,137],{"id":108,"alt":14,"title":14,"focalPoint":109,"width":110,"height":111,"thumbnail":112,"small":113,"medium":114,"responsiveImage":115,"video":14},"XqK7FQUMSBmKKC_gaSuC1Q",{"x":16,"y":16},2640,1157,"https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":116,"webpSrcSet":24,"sizes":25,"src":117,"width":27,"height":118,"aspectRatio":119,"alt":14,"title":14,"base64":120,"bgColor":121},"https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1756775109-tb_1.png?auto=format&fit=max&h=2440&q=85&w=2440",1069,2.2817631806395853,"data:image/png;base64,","#3fb983",{"id":123,"alt":14,"title":14,"focalPoint":124,"width":125,"height":126,"thumbnail":127,"small":128,"medium":129,"responsiveImage":130,"video":14},"KG2mTizMQ1qg61ZqLizFlg",{"x":16,"y":16},941,1158,"https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":131,"webpSrcSet":24,"sizes":132,"src":133,"width":125,"height":126,"aspectRatio":134,"alt":14,"title":14,"base64":135,"bgColor":136},"https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 235w,https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 470w,https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 705w,https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&fit=max&h=2440&q=85&w=2440 941w","(max-width: 941px) 100vw, 941px","https://www.datocms-assets.com/163973/1756775125-tb_2.png?auto=format&fit=max&h=2440&q=85&w=2440",0.812607944732297,"data:image/png;base64,","#0f53c3",{"id":138,"alt":14,"title":14,"focalPoint":139,"width":140,"height":126,"thumbnail":141,"small":142,"medium":143,"responsiveImage":144,"video":14},"Q6WNlLfZTX-R7IGFFdgQLg",{"x":16,"y":16},1580,"https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":145,"webpSrcSet":24,"sizes":146,"src":147,"width":140,"height":126,"aspectRatio":148,"alt":14,"title":14,"base64":149,"bgColor":150},"https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 395w,https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 790w,https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1185w,https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&fit=max&h=2440&q=85&w=2440 1580w","(max-width: 1580px) 100vw, 1580px","https://www.datocms-assets.com/163973/1756775145-tb_3.png?auto=format&fit=max&h=2440&q=85&w=2440",1.3644214162348878,"data:image/png;base64,","#f00808",{"id":152,"type":153,"title":154,"subtitle":155,"text":156,"media":157,"reverse":162},"D7vXgCpbTGGMFglIyfhnZw","text_device_block","The Solve.","Time Being is live—and making teams feel seen, not just tracked.","\u003Cp data-start=\"211\" data-end=\"565\">Employees can log hours in seconds, see how they&rsquo;re doing at a glance, and get nudges when their habits shift out of balance. Managers get contextual insight, when to step in, when to check in, and when to say &ldquo;take a day.&rdquo; And for those who want a little help focusing, there&rsquo;s even a built-in binaural beats player to support deep work.\u003C/p>\n\u003Cp data-start=\"567\" data-end=\"737\">Time Being turns time tracking into something more supportive, more human, and way more useful. Because protecting people&rsquo;s time starts with paying better attention to it.\u003C/p>",{"id":158,"media":159,"device":32},"LL6mkbd1RjWv938OtgrjVw",{"id":13,"alt":14,"title":14,"focalPoint":160,"width":17,"height":18,"thumbnail":19,"small":20,"medium":21,"responsiveImage":161,"video":14},{"x":16,"y":16},{"srcSet":23,"webpSrcSet":24,"sizes":25,"src":26,"width":27,"height":28,"aspectRatio":29,"alt":14,"title":14,"base64":30,"bgColor":31},false,{"id":164,"slug":165,"title":166,"featuredMedia":167},"MSLQrwVyRGOXOuM1qlTjnw","built-kindly","APEX Experts",{"id":168,"media":169,"device":32},"SoDSSNhTR9Gc_q0j8v1UpQ",{"id":170,"alt":14,"title":14,"focalPoint":171,"width":172,"height":173,"thumbnail":174,"small":175,"medium":176,"responsiveImage":177,"video":14},"an_HE_uGRcq6rKUK1XER5A",{"x":16,"y":16},2889,1689,"https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&fit=max&h=600&q=85&w=600","https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&fit=max&h=1000&q=85&w=1000","https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&fit=max&h=1500&q=85&w=1500",{"srcSet":178,"webpSrcSet":24,"sizes":25,"src":179,"width":27,"height":180,"aspectRatio":181,"alt":14,"title":14,"base64":182,"bgColor":183},"https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&dpr=0.25&fit=max&h=2440&q=85&w=2440 610w,https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&dpr=0.5&fit=max&h=2440&q=85&w=2440 1220w,https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&dpr=0.75&fit=max&h=2440&q=85&w=2440 1830w,https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&fit=max&h=2440&q=85&w=2440 2440w","https://www.datocms-assets.com/163973/1754416502-bk-cs-6.png?auto=format&fit=max&h=2440&q=85&w=2440",1426,1.7104795737122558,"data:image/png;base64,","#f36f35",1773147366330]